{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/chrome/**",
              "components/core/**",
              "site_src/js/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Urbanist))/i]",
        "message": "Font not provided by the design system. Available: Urbanist."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:direction|primary|disabled|onClick|className|key|ref|className|style|children)$/]",
        "message": "<ArrowButton> doesn't accept that prop. Declared props: direction, primary, disabled, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArrowButton'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:prev|next)$/]",
        "message": "<ArrowButton> direction must be one of 'prev' | 'next'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|pill|href|onClick|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, pill, href, onClick, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|dark|white|outline-dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'dark' | 'white' | 'outline-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CtaBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|lede|primaryLabel|secondaryLabel|onPrimary|onSecondary|key|ref|className|style|children)$/]",
        "message": "<CtaBanner> doesn't accept that prop. Declared props: eyebrow, title, lede, primaryLabel, secondaryLabel, onPrimary, onSecondary."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExclusiveCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|tag|title|description|hero|href|onClick|key|ref|className|style|children)$/]",
        "message": "<ExclusiveCard> doesn't accept that prop. Declared props: image, tag, title, description, hero, href, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onClick|children|className|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: active, onClick, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|className|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: placeholder, value, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHead'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|accent|title|lede|onDark|align|className|style|key|ref|className|style|children)$/]",
        "message": "<SectionHead> doesn't accept that prop. Declared props: eyebrow, accent, title, lede, onDark, align, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHead'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHead> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|blurb|columns|legal|copyright|key|ref|className|style|children)$/]",
        "message": "<SiteFooter> doesn't accept that prop. Declared props: logo, blurb, columns, legal, copyright."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:logo|homeHref|email|phone|nav|activeItem|ctaLabel|onCta|onNavClick|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: logo, homeHref, email, phone, nav, activeItem, ctaLabel, onCta, onNavClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoneCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|description|href|onClick|key|ref|className|style|children)$/]",
        "message": "<StoneCard> doesn't accept that prop. Declared props: image, title, description, href, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
